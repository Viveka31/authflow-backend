PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/authflow

JWT_SECRET=your_super_secret_jwt_key_here

# Brevo API (no SMTP — works on Render free tier)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=AuthFlow

# Your frontend URL — comma-separate if you have multiple
# e.g. both Netlify and Vercel:
# CLIENT_URL=https://myapp.netlify.app,https://myapp.vercel.app
CLIENT_URL=http://localhost:5173

RESET_TOKEN_EXPIRY=3600000
